source "https://rubygems.org"

# Newer ffi builds on current macOS / Apple Silicon toolchains (rb-inotify → listen → sass).
gem "ffi", ">= 1.16.0"

# Ruby 3.3+ no longer bundles rexml.
gem "rexml"

# Ruby 3+ needs webrick for `jekyll serve` (no longer in the default stdlib set).
gem "webrick"

gem "jekyll", "~> 4.3"
gem "jekyll-paginate"
gem "jekyll-seo-tag"
gem "jekyll-sitemap"
